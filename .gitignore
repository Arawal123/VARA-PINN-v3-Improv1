experiments/checkpoints/*
experiments/metrics/*
experiments/figures/*
experiments/tables/*
!experiments/logs/.gitkeep
!experiments/checkpoints/.gitkeep
!experiments/metrics/.gitkeep
!experiments/figures/.gitkeep
!experiments/tables/.gitkeep

